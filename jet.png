<!-- style | custom css | theme options -->
<style id="mfn-dnmc-theme-css">
/* Form */
.wpcf7-submit { background-color: #fdd100 !important;  }

/* Footer  */
#Footer .footer_copy { border-top: 0; }
#Footer .footer_copy .container  { border-top: 1px solid #fdd100; }

/* info post realisations */
.post-meta {

display:none !important;
}

/* date post realisations */
.fixed-nav .desc .date {

display:none !important;
}



/* centre les titres  */

@media screen and (max-width: 768px)
{
   #jet
    {
        margin-left: auto;
        margin-right: auto;
        text-align: center; 
    }
}


{

  #P2
    {
        margin-left: auto;
        margin-right: auto;
        text-align: center;
margin-top: 20cm;
    }
}




{

  #P1
    {
        margin-left: auto;
        margin-right: auto;
        text-align: center;
    }
}

@media screen and (max-width: 2880px)
{

#title1 a {
    color: #071323;
}

#title1 a:hover {
    color: #fdd100 !important;
    text-decoration: underline;

}

.faq .question .title .num {
    font-weight: 700;
    position: absolute;
    left: 27px;
    top: 20px;
    font-weight: bold;
    display: none;
}

.faq .question .title {
    padding: 20px 40px 20px 80px;
    font-size: 20px;
    position: relative;
    cursor: pointer;
    z-index: 2;
}

.faq .question.active .title, .accordion .question.active .title {
    color: #071323;
    font-size: 26px;
}


.langbf_links {
    width: 95%;
    height: 24px;
    margin: 0 auto;
    overflow: hidden;
}

.langbf_tooltip_top {
    background: url(images/black_arrow_bottom.png) no-repeat scroll center center transparent;
    padding: 27px 25px 15px;
    display:none;
font-size: 0px;
}

.langbf_tooltip_bottom {
    -webkit-box-sizing: content-box;
    -moz-box-sizing: content-box;
    box-sizing: content-box;
    color: #f7f7f7;
    display: none;
    font-size: 0px;
    font-style: italic;
    width: 145px;
    height: 30px;
    line-height: 30px;
    text-align: center;
    vertical-align: middle;
    z-index: 99999;
}

@media screen and (max-width: 400px)
{
.langbf_links {
    width: 32%;
    height: 24px;
    margin: 0 auto;
    overflow: hidden;
}

.langbf_right {
    float: initial;
    padding-right: 8px;
}

}

a.mfn-link-2 span, a:hover.mfn-link-2 span:before, a.hover.mfn-link-2 span:before, a.mfn-link-5 span, a.mfn-link-5:before {
    color: #0d1214;
}

a.mfn-link {
font-size: 12px;
}

#langbf_bar {
    background: none repeat scroll 0 0 #fff;
    border-bottom: 2px solid #ececec;
    -webkit-box-sizing: content-box;
    -moz-box-sizing: content-box;
    box-sizing: content-box;
    color: #DDDDD;
    font: 12px/28px Arial,Helvetica,sans-serif;
    height: 24px;
    left: 0;
    min-width: 80px;
    overflow: hidden;
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 99999;
}

.langbf_links {
    width: 90%;
    height: 24px;
    margin: 0 auto;
    overflow: hidden;
}

#Filters .filters_wrapper ul li a:hover, #Filters .filters_wrapper ul li.current-cat a {
    text-decoration: none;
    color: #000;
}





</style>

